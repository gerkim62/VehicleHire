# =============================================================================
# Vehicle Hire & Session Tracking System — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# --- Convex (required) -------------------------------------------------------
# Your Convex deployment URL — visible in the Convex dashboard or set
# automatically when you run `npx convex dev`.
CONVEX_DEPLOYMENT=

# The Convex HTTP URL for the React client
VITE_CONVEX_URL=

# The Convex site URL (used for HTTP actions / webhooks)
VITE_CONVEX_SITE_URL=

# Optional: set this in Vercel so the deploy step can publish the Convex backend
# from CI. Create a deployment key in the Convex dashboard and add it as
# CONVEX_DEPLOY_KEY in Vercel Environment Variables.
CONVEX_DEPLOY_KEY=

# --- Google OAuth (required for Google Sign-In) ------------------------------
# Create a project at https://console.cloud.google.com/
# Enable the "Google Identity Services" API
# Under Credentials → Create OAuth 2.0 Client ID (Web application)
# Set Authorised JavaScript origins:  http://localhost:5173
# Set Authorised redirect URIs:       http://localhost:5173/oauth-success
# Copy the Client ID below.
VITE_GOOGLE_CLIENT_ID=

# --- Paystack (required for payments) ----------------------------------------
# Create a free account at https://dashboard.paystack.com/
# Go to Settings → API Keys & Webhooks → copy the Test Public Key
# Use the LIVE key in production after going live.
VITE_PAYSTACK_PUBLIC_KEY=

# PAYSTACK_SECRET_KEY is the SECRET key (never expose to frontend).
# Set it in the Convex dashboard → Settings → Environment Variables.
# The server-side HTTP action uses it to call Paystack's Initialize Transaction API.
# Example (test): sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (Leave blank in .env.local — set it in Convex Dashboard only)

# --- Nodemailer / SMTP (required for email notifications) --------------------
# These are set in the Convex dashboard (not prefixed with VITE_),
# under Settings → Environment Variables, because they are used in
# server-side Convex Node.js actions.
#
# Any SMTP provider works. Examples:
#   Gmail:        smtp.gmail.com  port 465  (use an App Password — not your main password)
#   Mailgun:      smtp.mailgun.org  port 587
#   SendGrid:     smtp.sendgrid.net  port 587  (use "apikey" as SMTP_USER)
#   Brevo:        smtp-relay.brevo.com  port 587
#
# Add these in Convex dashboard → Settings → Environment Variables:
#   SMTP_HOST       e.g. smtp.gmail.com
#   SMTP_PORT       e.g. 465 (SSL) or 587 (TLS)
#   SMTP_SECURE     true for port 465, false for 587
#   SMTP_USER       your email / SMTP username
#   SMTP_PASS       your app password or SMTP password
#   EMAIL_FROM      "VehicleHire <noreply@yourdomain.com>"
